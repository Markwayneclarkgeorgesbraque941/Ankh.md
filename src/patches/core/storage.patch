+
+def _resolve_default_db_path() -> Path:
+    """Resolve default session DB path with strict scoped storage.
+
+    - Global scope / outside .agent: ~/.hermes/state.db
+    - Project scope (.agent): .agent/storage/state.db
+    """
+    scope_root = get_ankh_scope_root()
+    global_root = get_hermes_home()
+
+    if scope_root.resolve() == global_root.resolve():
+        return global_root / "state.db"
+
+    return scope_root / "storage" / "state.db"
+
+
+DEFAULT_DB_PATH = _resolve_default_db_path()
+DEFAULT_DB_PATH.parent.mkdir(parents=True, exist_ok=True)
 
