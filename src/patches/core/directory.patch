+def get_ankh_scope_root(start_dir: Optional[str] = None) -> Path:
+    """Return the active scope root for skills, sessions, and auxiliary runtime state."""
+    if os.getenv("HERMES_ANKH_SCOPE") == "global":
+        return get_hermes_home()
+    scope_root = os.getenv("HERMES_ANKH_SCOPE_ROOT")
+    if scope_root:
+        scoped = Path(scope_root).resolve()
+        if scoped.is_dir() and (scoped / "config.yaml").is_file():
+            return scoped
+    start = start_dir or os.getenv("MESSAGING_CWD") or os.getcwd()
+    local = find_agent_dir(start)
+    if local is not None:
+        return local
+    return get_hermes_home()
+
