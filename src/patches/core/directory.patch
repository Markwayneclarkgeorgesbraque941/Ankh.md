+def find_agent_dir(start_dir: Optional[str] = None) -> Optional[Path]:
+    """Find valid .agent directory by walking up from start_dir (default: cwd)."""
+    dir_path = Path(start_dir or os.getcwd()).resolve()
+    home_agent = (Path.home() / ".agent").resolve()
+    while dir_path != dir_path.parent:
+        agent_dir = dir_path / ".agent"
+        if agent_dir.exists() and agent_dir.is_dir():
+            if agent_dir.resolve() == home_agent:
+                dir_path = dir_path.parent
+                continue
+            if (agent_dir / "config.yaml").is_file():
+                return agent_dir
+        dir_path = dir_path.parent
+    return None
+
+
+def get_config_directories() -> List[Path]:
+    """Return config dirs in merge order: global first, then local (local overrides)."""
+    dirs: List[Path] = [get_hermes_home()]
+    if os.getenv("HERMES_ANKH_SCOPE") == "global":
+        return dirs
+    local = find_agent_dir()
+    if local is not None:
+        dirs.append(local)
+    return dirs
+
